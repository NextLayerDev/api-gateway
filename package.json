{
	"name": "upvox-gateway",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "tsx watch --env-file=.env src/server.ts",
		"build": "tsc --noEmit && tsup src/server.ts --format esm --target node22 --clean",
		"start": "node dist/server.js",
		"test": "vitest",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write ."
	},
	"dependencies": {
		"@fastify/cors": "^11.2.0",
		"@fastify/http-proxy": "^11.0.0",
		"@supabase/supabase-js": "^2.90.1",
		"fastify": "^5.6.2",
		"zod": "^4.3.5"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.11",
		"@types/node": "^22.0.0",
		"tsup": "^8.0.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^2.1.9"
	}
}
